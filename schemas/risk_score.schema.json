{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korpix.io/schemas/risk_score.schema.json",
  "title": "RiskScore",
  "description": "KorPIX Risk Score 계산 결과",
  "type": "object",
  "required": ["score","factors","thresholds"],
  "properties": {
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "factors": {
      "type": "object",
      "properties": {
        "actionTypeScore":    { "type": "integer" },
        "amountScore":        { "type": "integer" },
        "limitExceeded":      { "type": "boolean" },
        "abnormalPattern":    { "type": "boolean" },
        "systemStatusScore":  { "type": "integer" },
        "vixScore":           { "type": ["integer","null"] },
        "lossLimitScore":     { "type": ["integer","null"] },
        "concentrationScore": { "type": ["integer","null"] },
        "privacyGradeScore":  { "type": ["integer","null"] },
        "delegationScore":    { "type": ["integer","null"] }
      }
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "autoApprove":  { "type": "integer", "const": 30 },
        "userConfirm":  { "type": "integer", "const": 60 },
        "adminApprove": { "type": "integer", "const": 80 }
      }
    }
  }
}
