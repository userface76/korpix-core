{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korpix.io/schemas/action_record.schema.json",
  "title": "ActionRecord",
  "description": "KorPIX AI 행동 감사 기록 표준 구조 v0.1",
  "type": "object",
  "required": [
    "actionId","agentId","userId","terminalId",
    "actionType","payload","riskScore","policyDecision",
    "policyEngineVer","executionResult",
    "timestamp","prevHash","hash","digitalSignature"
  ],
  "properties": {
    "actionId":        { "type": "string", "format": "uuid" },
    "agentId":         { "type": "string" },
    "userId":          { "type": "string", "description": "SHA-256 해시값 (원본 미저장)" },
    "terminalId":      { "type": "string" },
    "actionType": {
      "type": "string",
      "enum": ["PAYMENT","INVESTMENT","PURCHASE_REQUEST","CIVIC_SERVICE","SYSTEM"]
    },
    "payload":         { "type": "object" },
    "riskScore":       { "type": "integer", "minimum": 0, "maximum": 100 },
    "policyDecision": {
      "type": "string",
      "enum": ["AUTO_APPROVE","USER_CONFIRM","ADMIN_APPROVE","DENY"]
    },
    "policyEngineVer": { "type": "string" },
    "executionResult": {
      "type": "string",
      "enum": ["SUCCESS","BLOCKED","PENDING","FAILED"]
    },
    "timestamp":        { "type": "string", "format": "date-time" },
    "prevHash":         { "type": "string", "minLength": 64, "maxLength": 64 },
    "hash":             { "type": "string", "minLength": 64, "maxLength": 64 },
    "digitalSignature": { "type": "string" }
  },
  "additionalProperties": false
}
