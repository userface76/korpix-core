{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korpix.io/schemas/policy_decision.schema.json",
  "title": "PolicyDecision",
  "description": "KorPIX Policy Engine 결정 결과",
  "type": "object",
  "required": ["resultId","requestId","decision","riskScore","reasons","engineVersion","decidedAt"],
  "properties": {
    "resultId":      { "type": "string", "format": "uuid" },
    "requestId":     { "type": "string", "format": "uuid" },
    "decision": {
      "type": "string",
      "enum": ["AUTO_APPROVE","USER_CONFIRM","ADMIN_APPROVE","DENY"]
    },
    "riskScore":     { "type": "integer", "minimum": 0, "maximum": 100 },
    "riskDetails": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["factor","score","reason"],
        "properties": {
          "factor": { "type": "string" },
          "score":  { "type": "integer" },
          "reason": { "type": "string" }
        }
      }
    },
    "reasons":       { "type": "array", "items": { "type": "string" } },
    "approvalChain": { "type": ["object","null"] },
    "requiresNotify":{ "type": "boolean" },
    "notifyMessage": { "type": ["string","null"] },
    "engineVersion": { "type": "string" },
    "decidedAt":     { "type": "string", "format": "date-time" }
  }
}
