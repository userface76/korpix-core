5. 기술 구현 명세

5.1 구매 특화 Action Record 데이터 구조
UC-001 ActionRecord를 상속하고 기업 구매에 필요한 ERP 연동 필드와 결재 체인 정보를 추가합니다.

// PurchaseActionRecord — UC-001 ActionRecord 기업 구매 확장 (TypeScript)
interface PurchaseActionRecord extends ActionRecord {
  actionType: 'PURCHASE_REQUEST';

  payload: {
    prId:          string;   // 구매 요청서 고유 ID (PR-YYYYMMDD-XXXX)
    itemCode:      string;   // ERP 품목 코드
    itemName:      string;   // 품목명
    quantity:      number;   // 수량
    unitPrice:     number;   // 단가 (KRW)
    totalAmount:   number;   // 총 금액 (KRW)
    category:      PurchaseCategory;  // CONSUMABLE | IT_EQUIPMENT | SERVICE | ASSET
    urgency:       'NORMAL' | 'URGENT';
    justification: string;   // 구매 사유
  };

  // 조직 / 예산 필드
  orgContext: {
    requesterId:   string;   // 요청자 사번
    departmentId:  string;   // 부서 코드
    budgetCode:    string;   // ERP 예산 코드
    budgetRemaining: number; // 요청 시점 잔여 예산
    fiscalYear:    number;   // 회계연도
  };

  // 결재 체인 — Policy Engine이 자동 생성
  approvalChain: Array<{
    tier:       number;      // 1 ~ 5
    approverId: string;      // 결재자 사번
    role:       string;      // '팀장' | '재무팀' | 'CFO' | '이사회'
    status:     ApprovalStatus;  // PENDING | APPROVED | REJECTED
    approvedAt: string | null;   // ISO 8601
    signature:  string | null;   // 결재자 디지털 서명
    comment:    string | null;   // 결재 의견
  }>;

  // ERP 연동 결과
  erpResult: {
    poId:       string | null;  // 생성된 발주 번호 (PO-YYYYMMDD-XXXX)
    erpStatus:  'CREATED' | 'PENDING' | 'FAILED';
    erpTimestamp: string | null;
  };
}

5.2 구매 특화 Policy Engine — Risk Score 계산
기본 금액 점수에 품목 위험도·예산 소진율·긴급 여부·반복 구매 패턴을 더해 승인 티어를 결정합니다.

# Purchase Risk Evaluator — 구매 특화 Risk Score (Python)
class PurchaseRiskEvaluator:

    AMOUNT_TIERS = [
        (1_000_000,  0),   # 100만 미만 → +0
        (5_000_000, 15),   # 500만 미만 → +15
        (20_000_000, 35),  # 2,000만 미만 → +35
        (100_000_000, 55), # 1억 미만 → +55
    ]

    CATEGORY_RISK = {
        'CONSUMABLE':   0,    # 소모품 — 저위험
        'SERVICE':     10,    # 서비스 계약 — 중간
        'IT_EQUIPMENT': 15,   # IT 장비 — 중간
        'ASSET':        25,   # 자산성 구매 — 고위험
    }

    def calculate(self, req: PurchaseActionRequest) -> int:
        score = 0

        # 1. 금액 기반 점수
        for threshold, points in self.AMOUNT_TIERS:
            if req.totalAmount < threshold:
                score += points
                break
        else:
            return Decision.DENY  # 1억 초과 → 강제 이사회 이관

        # 2. 품목 유형 위험도
        score += self.CATEGORY_RISK.get(req.category, 20)

        # 3. 부서 예산 소진율
        budget_used = erp.get_budget_used_rate(req.departmentId, req.budgetCode)
        if budget_used > 1.0:
            return Decision.DENY   # 예산 초과 → 즉시 차단
        elif budget_used > 0.90:   score += 20  # 90% 이상 소진
        elif budget_used > 0.75:   score += 10  # 75% 이상 소진

        # 4. 긴급 구매 가중치
        if req.urgency == 'URGENT':
            score += 15
            # 당월 긴급 사용 횟수 체크 (3회 이상 경보)
            if erp.get_urgent_count(req.departmentId) >= 3:
                score += 10  # 긴급 남용 패턴 가중치

        # 5. 동일 품목 반복 구매 (30일 내 3회 이상)
        if erp.get_recent_purchase_count(req.itemCode, days=30) >= 3:
            score += 8  # 분할 발주 패턴 감지

        # 최종 티어 결정
        if score <= 25: return Decision.AUTO_APPROVE          # Tier 1
        if score <= 50: return Decision.USER_CONFIRM_L1       # Tier 2: 팀장
        if score <= 70: return Decision.USER_CONFIRM_L2       # Tier 3: 팀장 + 재무
        if score <= 85: return Decision.ADMIN_APPROVE         # Tier 4: CFO
        return          Decision.DENY                         # Tier 5: 이사회

5.3 결재 체인 자동 생성 — OrgChart Connector
Policy Engine이 승인 티어를 결정하면, OrgChart Connector가 조직도 데이터를 조회하여 실제 결재자 목록을 자동으로 구성합니다.

# OrgChart Connector — 조직도 기반 결재 체인 자동 생성 (Python)
class ApprovalChainBuilder:

    def build(self, req: PurchaseActionRequest,
              decision: Decision,
              is_urgent: bool = False) -> list[ApprovalStep]:

        chain = []
        timeout_hrs = 2 if is_urgent else 24  # 긴급: 2시간, 일반: 24시간

        if decision == Decision.USER_CONFIRM_L1:
            # Tier 2: 팀장만
            manager = orgchart.get_manager(req.requesterId)
            chain.append(ApprovalStep(
                tier=2, approverId=manager.id,
                role='팀장', timeoutHrs=timeout_hrs
            ))

        elif decision == Decision.USER_CONFIRM_L2:
            # Tier 3: 팀장 → 재무팀 (직렬, 긴급 시 병렬)
            manager  = orgchart.get_manager(req.requesterId)
            finance  = orgchart.get_finance_approver(req.departmentId)
            parallel = is_urgent  # 긴급 시 병렬 처리

            chain.append(ApprovalStep(tier=3, approverId=manager.id,
                role='팀장', timeoutHrs=timeout_hrs, parallel=parallel))
            chain.append(ApprovalStep(tier=3, approverId=finance.id,
                role='재무팀', timeoutHrs=timeout_hrs, parallel=parallel))

        elif decision == Decision.ADMIN_APPROVE:
            # Tier 4: 팀장 → 재무 → CFO
            manager = orgchart.get_manager(req.requesterId)
            finance = orgchart.get_finance_approver(req.departmentId)
            cfo     = orgchart.get_cfo()
            for role, approver in [('팀장',manager),('재무팀',finance),('CFO',cfo)]:
                chain.append(ApprovalStep(tier=4, approverId=approver.id,
                    role=role, timeoutHrs=48))

        return chain

    def handle_timeout(self, step: ApprovalStep):
        # 타임아웃 발생 시 상위 결재자에게 자동 에스컬레이션
        escalation_target = orgchart.get_deputy(step.approverId)
        notify.send_escalation(escalation_target, step)
        audit.record_event('APPROVAL_TIMEOUT_ESCALATION', step)

5.4 ERP 자동 발주 연동
최종 승인 완료 시 ERP API를 통해 구매 발주서(PO)를 자동 생성하고 예산을 즉시 차감합니다.

# ERP 자동 발주 생성 — SAP / Oracle / 더존 ERP 어댑터 (Python)
class ERPAdapter:

    def create_purchase_order(self,
                              pr: PurchaseActionRecord) -> ERPResult:
        # 모든 결재 서명이 완료됐는지 최종 확인
        if not all(s.status == 'APPROVED' for s in pr.approvalChain):
            raise PolicyViolation('미완료 결재 단계 존재 — PO 생성 불가')

        po_payload = {
            'vendor_code':  self._resolve_vendor(pr.payload.itemCode),
            'item_code':    pr.payload.itemCode,
            'quantity':     pr.payload.quantity,
            'unit_price':   pr.payload.unitPrice,
            'budget_code':  pr.orgContext.budgetCode,
            'cost_center':  pr.orgContext.departmentId,
            'pr_reference': pr.payload.prId,      # PR↔PO 연결
            'requester':    pr.orgContext.requesterId,
        }

        result = self.erp_api.post('/purchase-orders', po_payload)

        # 예산 자동 차감
        self.erp_api.deduct_budget(
            budget_code=pr.orgContext.budgetCode,
            amount=pr.payload.totalAmount,
            reference=result['po_id']
        )

        return ERPResult(
            poId=result['po_id'],
            status='CREATED',
            timestamp=now()
        )


