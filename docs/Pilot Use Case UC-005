6.2 TPM PCR 기반 감사 로그 확장

// tpm_audit_extend.c
// TPM PCR Extend — 감사 블록 해시를 TPM에 기록 (C)
// PCR[14]을 KorPIX 감사 전용 레지스터로 예약

#define KORPIX_AUDIT_PCR  14

int korpix_extend_audit_pcr(const uint8_t *block_hash,
                             size_t hash_len)
{
    ESYS_CONTEXT *esys_ctx;
    TSS2_RC rc;

    // TPM2 Software Stack 초기화
    rc = Esys_Initialize(&esys_ctx, NULL, NULL);
    if (rc != TSS2_RC_SUCCESS) return -1;

    // PCR Extend — 새 블록 해시를 PCR[14]에 연속 반영
    // PCR_new = SHA256(PCR_current || block_hash)
    // → PCR 값을 이전 상태로 되돌리는 것이 물리적으로 불가능
    TPML_DIGEST_VALUES digests = {
        .count = 1,
        .digests[0].hashAlg = TPM2_ALG_SHA256,
    };
    memcpy(digests.digests[0].digest.sha256, block_hash, hash_len);

    rc = Esys_PCR_Extend(esys_ctx,
                         KORPIX_AUDIT_PCR,  // PCR 인덱스
                         ESYS_TR_PASSWORD,
                         ESYS_TR_NONE, ESYS_TR_NONE,
                         &digests);

    Esys_Finalize(&esys_ctx);
    return (rc == TSS2_RC_SUCCESS) ? 0 : -1;
}


