7.2 NPU PQC 오프로딩 구조

// pqc_hw_signer.c  (TEE + NPU 연동)
// PQC NPU 오프로딩 — Dilithium3 서명 생성 (C, TEE 내부)
// NPU를 다항식 연산(NTT) 가속기로 활용

typedef struct {
    npu_handle_t  npu;          // NPU 디바이스 핸들
    tpm_handle_t  tpm;          // TPM 핸들 (최종 키 서명)
} PQCSigner;

int pqc_dilithium_sign_hw(
    PQCSigner *signer,
    const uint8_t *message, size_t msg_len,
    uint8_t *sig_out,       size_t *sig_len)
{
    // 1. 메시지 해시 (CPU — SHA3-256)
    uint8_t mu[64];
    sha3_256(message, msg_len, mu);

    // 2. NTT (Number Theoretic Transform) — NPU 오프로딩
    //    Dilithium의 핵심 연산(다항식 곱셈)을 NPU에 위임
    poly_vec_t w1, cs1, cs2;
    npu_submit_ntt(signer->npu, mu, sizeof(mu), &w1);  // 비동기 제출
    npu_wait_complete(signer->npu, NPU_TIMEOUT_MS);    // 완료 대기
    npu_get_result(signer->npu, &w1);

    // 3. 거부 샘플링 (CPU — 연산량 적음)
    int retry = 0;
    while (retry++ < MAX_REJECTION) {
        if (dilithium_make_hint(&w1, &cs1, &cs2)) break;
    }

    // 4. 최종 서명 패킹 (CPU)
    dilithium_pack_sig(sig_out, sig_len, &w1, &cs2);

    // 5. TPM으로 서명에 추가 인증 도장 (HW 신뢰 루트 연결)
    tpm_certify(signer->tpm, sig_out, *sig_len);

    return 0;
}


