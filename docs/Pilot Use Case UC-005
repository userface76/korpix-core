5.2 TEE 내 Policy Engine TA 핵심 코드

// policy_engine_ta.c  (TEE Secure World)
// Policy Engine Trusted Application — TEE Secure World (C)
// OP-TEE TA 진입점 (GlobalPlatform TEE API 준수)

TEE_Result TA_InvokeCommandEntryPoint(
    void *sess_ctx,
    uint32_t cmd_id,
    uint32_t param_types,
    TEE_Param params[4])
{
    switch (cmd_id) {
    case CMD_EVALUATE_RISK:
        return evaluate_risk_score(params);   // Risk Score 계산
    case CMD_SIGN_AUDIT_RECORD:
        return sign_audit_record(params);     // 감사 레코드 서명
    case CMD_VERIFY_ATTESTATION:
        return verify_pcr_quote(params);      // Remote Attestation
    default:
        return TEE_ERROR_NOT_SUPPORTED;
    }
}

// Risk Score 계산 — TEE 내부에서만 실행
static TEE_Result evaluate_risk_score(
    TEE_Param params[4])
{
    struct ActionRequest *req = params[0].memref.buffer;
    uint32_t *score_out       = params[1].memref.buffer;
    uint32_t *decision_out    = params[2].memref.buffer;

    uint32_t score = 0;

    // 1. 행동 유형 기본 점수 (TEE 내 정책 테이블 조회)
    score += policy_table_lookup(req->action_type);

    // 2. 금액 기반 점수
    score += amount_risk_score(req->amount);

    // 3. 사용자 정책 — TEE Secure Storage에서 읽기
    UserPolicy policy;
    tee_read_user_policy(req->user_id, &policy);
    if (req->amount > policy.monthly_limit) score += 30;

    // 4. 결정 (TEE 밖으로 점수 원본 미노출 — 결정값만 반환)
    *score_out    = score;   // 감사 목적으로만 반환
    *decision_out = score < 30 ? DECISION_AUTO_APPROVE :
                   score < 60 ? DECISION_USER_CONFIRM  :
                   score < 80 ? DECISION_ADMIN_APPROVE :
                                DECISION_DENY;
    return TEE_SUCCESS;
}

5.3 Normal World → TEE 호출 구조 (CA 코드)

# policy_engine_hw_client.py  (Normal World CA)
# TEE Client Application — Normal World에서 TEE 호출 (Python)
# OP-TEE Python 바인딩 또는 C FFI 경유

class PolicyEngineHWClient:
    TA_UUID = '12345678-1234-1234-1234-policyta001'  # TA 고유 UUID

    def evaluate_action(self, action: ActionRequest) -> PolicyDecision:
        # TEE 세션 열기
        ctx    = TEEContext()
        sess   = ctx.open_session(self.TA_UUID)

        # 공유 메모리에 요청 데이터 복사
        shm_in  = ctx.allocate_shared_memory(sizeof(ActionRequest))
        shm_out = ctx.allocate_shared_memory(sizeof(PolicyResult))
        shm_in.write(action.serialize())

        # TEE invoke — Secure World에서 Risk 계산
        params = [
            TEEParam.memref_input(shm_in),
            TEEParam.memref_output(shm_out),
            TEEParam.value_output(),   # decision enum
            TEEParam.value_output(),   # risk_score (감사용)
        ]
        ret = sess.invoke_command(CMD_EVALUATE_RISK, params)

        if ret != TEE_SUCCESS:
            raise TEEInvocationError(f'Policy Engine TA 오류: {ret}')

        result = PolicyResult.deserialize(shm_out.read())

        # TEE 세션 닫기 — Secure World 메모리 정리
        sess.close()
        ctx.finalize()
        return result


6. Audit Network 하드웨어 연동

소프트웨어 환경에서는 감사 기록이 파일 시스템에 저장되어 OS 권한을 가진 공격자가 수정 가능했습니다. 하드웨어 환경에서는 TPM PCR 기반 하드웨어 로그와 NVMe Write-Once 파티션이 결합되어 물리적 수준의 불변성을 보장합니다.

6.1 하드웨어 감사 기록 파이프라인

단계	위치	처리 내용	불변성 보장 수단
생성	TEE — audit_signer_ta	Action Record 직렬화 → TPM AIK 서명 생성	TEE 격리 + TPM 하드웨어 서명
1차 저장	NVMe 감사 파티션	서명된 레코드 Write-Once 파티션에 순차 저장	하드웨어 쓰기 보호 + AES-256 암호화
PCR 기록	TPM PCR[14]	감사 파티션 최신 블록 해시를 TPM PCR에 extend	TPM 하드웨어 — PCR 값 되돌리기 불가
2차 동기화	Audit Network	원격 분산 원장에 비동기 복제 (5분 배치)	블록체인형 해시 체인 + 다중 노드
