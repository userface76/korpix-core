6. 기술 구현 명세

6.1 행정 특화 Action Record 데이터 구조
UC-001 기본 ActionRecord를 상속하고 공공 행정에 특화된 개인정보 보호 필드와 위임 관계 필드를 추가합니다. 핵심 원칙은 개인정보 원본 미저장입니다.

// CivicActionRecord — UC-001 ActionRecord 행정 서비스 확장 (TypeScript)
interface CivicActionRecord extends ActionRecord {
  actionType: 'CIVIC_SERVICE';

  payload: {
    serviceCode:   string;   // 'LOCAL_TAX' | 'DOC_ISSUANCE' | 'WELFARE' | ...
    serviceName:   string;   // 서비스명 (지방세 납부, 주민등록등본 발급 등)
    agencyCode:    string;   // 기관 코드 (GOV24 · MOHW · NHI · ...)
    amount:        number | null;  // 납부 금액 (해당 없으면 null)
    documentType:  string | null;  // 발급 서류 유형
  };

  // 개인정보 보호 — 원본 미저장, 해시만 보존
  privacyFields: {
    subjectIdHash:     string;   // 주민번호 SHA-256 해시 (원본 절대 미저장)
    privacyGrade:      1 | 2 | 3 | 4;  // 처리한 개인정보 최고 등급
    dataRetentionDays: number;   // 원본 데이터 보존 기간 (0 = 즉시 삭제)
    localProcessOnly:  boolean;  // true이면 외부 전송 없이 로컬 처리
  };

  // 위임 관계 (대리 행동 시에만 사용)
  delegation?: {
    isDelegated:      boolean;
    principalIdHash:  string;   // 본인 ID 해시
    delegateIdHash:   string;   // 대리인 ID 해시
    delegationSig:    string;   // 본인 위임 동의 디지털 서명
    delegationExpiry: string;   // 위임 만료 시각 (ISO 8601)
  };

  // 공공 API 응답 (영수증 번호 등 비개인정보만)
  publicApiResult: {
    receiptNumber: string | null;
    status:        'SUCCESS' | 'FAILED' | 'PENDING';
    agencyTimestamp: string;
  };
}

6.2 행정 특화 Policy Engine — Civic Risk Evaluator
행정 서비스는 금액보다 '개인정보 등급'과 '위임 관계 유효성'이 핵심 제어 변수입니다.

# Civic Risk Evaluator — 행정 서비스 특화 Risk Score (Python)
class CivicRiskEvaluator:

    SERVICE_BASE_RISK = {
        'LOCAL_TAX':      10,  # 지방세 납부 — 저위험
        'UTILITY':        10,  # 공과금 납부 — 저위험
        'DOC_ISSUANCE':   25,  # 서류 발급 — 중간 (주민번호 사용)
        'WELFARE':        40,  # 복지 신청 — 고위험 (건강정보)
        'RESERVATION':    15,  # 공공 예약 — 저위험
        'PERMIT':         50,  # 인허가 신청 — 고위험
    }

    def calculate(self, req: CivicActionRequest) -> int:
        score = self.SERVICE_BASE_RISK.get(req.serviceCode, 30)

        # 1. 개인정보 등급 가중치
        privacy_grade = self._assess_privacy_grade(req)
        if   privacy_grade == 1: score += 0
        elif privacy_grade == 2: score += 15
        elif privacy_grade == 3: score += 30
        elif privacy_grade == 4: return Decision.DENY  # 최고민감 → 즉시 차단

        # 2. 대리 행동 검증
        if req.isDelegated:
            if not self._verify_delegation(req):
                return Decision.DENY   # 위임 관계 미검증 → 차단
            score += 20  # 대리 행동 자체 가중치

        # 3. 접근 빈도 이상 탐지 (10분 내 5회 이상)
        if access_log.get_count(req.userId, minutes=10) >= 5:
            score += 50  # 비정상 패턴 → DENY 방향

        # 4. 납부 금액 (공과금 한도 초과 여부)
        if req.amount and req.amount > user_policy.civic_payment_limit:
            score += 25

        # 최종 결정
        if score <= 20: return Decision.AUTO_APPROVE   # 자동 처리
        if score <= 45: return Decision.USER_CONFIRM   # 사용자 확인
        if score <= 70: return Decision.ADMIN_CONFIRM  # 관리자 확인
        return          Decision.DENY                  # 차단

    def _verify_delegation(self, req) -> bool:
        # 위임 서명 유효성 + 만료 시각 + 위임 범위 일치 확인
        return (delegation_store.verify_sig(req.delegation.sig)
                and req.delegation.expiry > now()
                and req.serviceCode in req.delegation.allowedServices)

6.3 공공 API 통합 게이트웨이
기관별로 파편화된 공공 API를 KorPIX가 단일 인터페이스로 추상화합니다. AI 에이전트는 기관별 API 차이를 알 필요 없이 서비스 코드만 전달합니다.

# 공공 API 통합 게이트웨이 — 기관별 API 추상화 (Python)
class PublicServiceGateway:

    ADAPTERS = {
        'GOV24':    Gov24Adapter(),    # 정부24 — 민원 발급
        'NHI':      NHIAdapter(),      # 국민건강보험
        'MOHW':     MOHWAdapter(),     # 보건복지부 — 복지로
        'LOCALEX':  LocalTaxAdapter(), # 지방세 납부
        'KEPCO':    KEPCOAdapter(),    # 한국전력
        'KOGAS':    KOGASAdapter(),    # 한국가스공사
    }

    def execute(self, req: CivicActionRequest,
                auth_token: str) -> PublicApiResult:

        adapter = self.ADAPTERS.get(req.agencyCode)
        if not adapter:
            raise UnsupportedAgency(f'{req.agencyCode} 미연동 기관')

        # 모든 어댑터는 동일한 인터페이스 구현
        result = adapter.call(
            service_code = req.serviceCode,
            payload      = self._build_payload(req),
            auth_token   = auth_token,  # 기관별 인증 토큰
        )

        # 응답 표준화 (기관별 응답 형식 통일)
        return PublicApiResult(
            success      = result.is_ok(),
            receiptNumber= result.get('receipt_no') or result.get('접수번호'),
            rawResponse  = result.sanitized(),  # 개인정보 제거 후 저장
        )

    def _build_payload(self, req) -> dict:
        # 개인정보 최소 전송 원칙 — 꼭 필요한 필드만 포함
        base = { 'service_code': req.serviceCode }
        if req.amount:        base['amount']    = req.amount
        if req.documentType:  base['doc_type']  = req.documentType
        # 주민번호는 인증 토큰으로 대체, 직접 전송 금지
        return base


