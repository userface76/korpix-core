4. 기술 구현 명세

4.1 투자 특화 Action Record 데이터 구조
UC-001 ActionRecord를 상속하고 투자 전용 필드를 추가합니다. 규제 감사에 필요한 투자 판단 근거(strategyBasis)가 핵심 추가 필드입니다.

// InvestmentActionRecord — UC-001 ActionRecord 확장 (TypeScript)
interface InvestmentActionRecord extends ActionRecord {
  actionType: 'INVESTMENT';

  payload: {
    ticker:       string;       // 'KODEX200' | 'TIGER_반도체' | ...
    quantity:     number;       // 매수 수량
    unitPrice:    number;       // 주문 단가 (KRW)
    totalAmount:  number;       // 총 주문 금액 (KRW)
    orderType:    'MARKET' | 'LIMIT';
  };

  // 투자 특화 필드
  strategyBasis: {
    vixAtExecution:    number;  // 실행 시점 VIX 지수
    portfolioLossRate: number;  // 현재 포트폴리오 손실률 (%)
    sectorConcentration: number; // 해당 섹터 비중 (%)
    strategyName:      string;  // 사용한 투자 전략명
    dataSourceHash:    string;  // 판단 근거 데이터 해시 (변조 방지)
  };

  regulatoryFields: {
    investorRiskGrade:  1 | 2 | 3 | 4 | 5;  // 투자자 위험 등급
    suitabilityCheck:   boolean;             // 적합성 원칙 통과 여부
    retentionPeriodYr:  5;                   // 자본시장법 5년 보존
  };
}

4.2 투자 특화 Policy Engine — Risk Score 확장
UC-001의 기본 Risk Score에 투자 전용 5개 요소를 추가합니다. 특히 VIX 지수와 손실 한도는 투자 영역에서 가장 중요한 제어 변수입니다.

# Investment Risk Evaluator — UC-001 RiskEvaluator 확장 (Python)
class InvestmentRiskEvaluator(RiskEvaluator):

    def calculate(self, req: InvestmentActionRequest) -> int:
        score = super().calculate(req)   # UC-001 기본 점수 상속

        # 투자 특화 요소 1: 시장 변동성 (VIX)
        vix = market_data.get_vix()
        if   vix < 15:  score += 0       # 안정 구간
        elif vix < 25:  score += 10      # 보통 변동성
        elif vix < 35:  score += 25      # 높은 변동성
        else:           score += 50      # 시장 공포 구간 → 서킷 브레이커

        # 투자 특화 요소 2: 포트폴리오 손실률
        loss = portfolio.get_loss_rate(req.userId)
        if loss >= req.userPolicy.lossLimit:
            score += 60                  # 손실 한도 초과 → 강제 차단

        # 투자 특화 요소 3: 섹터 집중도
        conc = portfolio.sector_concentration(req.userId, req.sector)
        if   conc < 0.30: score += 0
        elif conc < 0.40: score += 15    # 경고 구간
        else:             score += 35    # 집중투자 위험

        # 투자 특화 요소 4: 월 투자 한도 소진율
        used = portfolio.monthly_used_rate(req.userId)
        if used > 0.80: score += 20      # 한도 80% 이상 소진

        # 투자 특화 요소 5: 투자자 위험 등급 vs 상품 위험도 불일치
        if req.productRiskGrade > req.userRiskGrade:
            score += 30                  # 적합성 원칙 위반 위험

        # 서킷 브레이커 — VIX 35 이상 시 모든 투자 행동 DENY
        if vix >= 35:
            return Decision.DENY  # 점수와 무관하게 강제 차단

        # 최종 결정 분기
        if score < 35:  return Decision.AUTO_APPROVE
        if score < 60:  return Decision.USER_CONFIRM
        if score < 80:  return Decision.ADMIN_APPROVE
        return          Decision.DENY

4.3 투자 Action Record — 감사 기록 생성

# 투자 감사 기록 생성 — 전략 근거 해시 포함 (Python)
def create_investment_record(action: InvestmentAction, prev_hash: str) -> dict:

    # 투자 판단 근거 데이터를 해시로 보존 (원본 데이터 크기 문제 해결)
    strategy_data = {
        'vix':         action.vix_at_execution,
        'prices':      action.market_prices_snapshot,
        'portfolio':   action.portfolio_snapshot,
        'strategy':    action.strategy_name,
    }
    strategy_hash = hashlib.sha256(
        json.dumps(strategy_data, sort_keys=True).encode()
    ).hexdigest()

    record = {
        **base_fields(action, prev_hash),  # UC-001 기본 필드

        # 투자 특화 필드
        'ticker':                action.ticker,
        'quantity':              action.quantity,
        'total_amount':          action.total_amount,
        'vix_at_execution':      action.vix_at_execution,
        'portfolio_loss_rate':   action.portfolio_loss_rate,
        'sector_concentration':  action.sector_concentration,
        'strategy_basis_hash':   strategy_hash,  # 근거 원본은 별도 저장

        # 규제 필드
        'investor_risk_grade':   action.investor_risk_grade,
        'suitability_check':     action.suitability_check,
        'retention_period_yr':   5,  # 자본시장법 의무 보존 기간
    }

    record['hash']      = sha256(record)
    record['signature'] = terminal.sign(record['hash'])
    return record

4.4 서킷 브레이커 — 시장 급락 자동 차단

# Circuit Breaker — 시장 급락 감지 시 전체 투자 행동 차단 (Python)
class CircuitBreaker:
    KOSPI_DROP_THRESHOLD = -0.05   # 코스피 -5%
    VIX_THRESHOLD        = 30.0    # VIX 30 이상

    def check(self) -> bool:
        kospi_change = market.get_daily_change('KOSPI')
        vix          = market.get_vix()

        triggered = (kospi_change <= self.KOSPI_DROP_THRESHOLD
                     or vix >= self.VIX_THRESHOLD)

        if triggered:
            self._activate()       # 전체 AI 투자 행동 HOLD
            self._cancel_pending() # 진행 중 주문 취소
            self._notify_all()     # 전체 사용자 알림
            audit.record_event('CIRCUIT_BREAKER_TRIGGERED', {
                'kospi_change': kospi_change,
                'vix': vix,
                'affected_users': self._get_active_users(),
            })
        return triggered

    def deactivate(self, user_id: str, manual_confirm: bool):
        if not manual_confirm:
            raise PolicyViolation('서킷 브레이커 해제는 수동 확인 필수')
        audit.record_event('CIRCUIT_BREAKER_DEACTIVATED', {
            'user_id': user_id,
            'timestamp': now(),
        })


